# Database -- connection string from Neon, RDS, Cloud SQL, etc.
DATABASE_URL=postgresql://user:password@host:5432/dbname
DB_SSL=true
DB_PASSWORD=your-db-password

# Cloud provider region (AWS, GCP, Azure)
AWS_REGION=us-east-1

# Anthropic -- powers AI assistant/search features in the clone
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Cloudflare -- CDN and edge caching (optional, only if clone needs edge layer)
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ZONE_ID=

# Dashboard -- simple auth key for the admin dashboard (api-key strategy only)
DASHBOARD_KEY=your-dashboard-key

# Session -- secret for signing session cookies (email-password and oauth strategies)
# Generate with: openssl rand -hex 32
SESSION_SECRET=

# OAuth -- Google provider credentials (oauth strategy only)
# Create at: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# OAuth -- GitHub provider credentials (oauth strategy only)
# Create at: https://github.com/settings/developers
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
