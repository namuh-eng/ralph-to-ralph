# Database
DATABASE_URL=postgresql://user:password@host:5432/dbname
DB_SSL=true

# Cloud provider credentials (set by preflight.sh or manually)
AWS_REGION=us-east-1
DB_PASSWORD=your-db-password

# Optional: Cloudflare DNS for domain verification
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ZONE_ID=

# Dashboard auth
DASHBOARD_KEY=your-dashboard-key
